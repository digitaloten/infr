#version 460
// Broadcast bias add: dst[i] = x[i] + bias[i % n] — a length-`n` bias added to every one of the
// `rows` rows (a projection's Wx + b; Qwen2/2.5 q/k/v). One thread per element (`total = rows*n`).
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PC { uint n; uint total; } pc;
layout(binding = 0) readonly buffer XB { float x[]; };
layout(binding = 1) readonly buffer BB { float bias[]; };
layout(binding = 2) buffer DB { float dst[]; };

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.total) { return; }
    dst[i] = x[i] + bias[i % pc.n];
}
