#!/usr/bin/env bash
# Run the SAME prompt on infr and llama.cpp, show both answers, compare prompt/decode tok/s.
# Same model + GPU (7900 XTX, flash attn). Needs: llama-cpp-vulkan (llama-cli), python3.
#
# Usage:  ./bash_prompt ["prompt"] [model.gguf]
# Env:    MAXNEW=N  cap generated tokens (default 1024)   DEV=Vulkan0  llama device
set -euo pipefail

PROMPT="${1:-Hello, make me a small bash script that demonstrates most common bash text manipulation tricks}"
MODEL="${2:-${INFR_MODEL:-/home/mxaddict/Projects/models/qwen3-0.6b/Qwen3-0.6B-Q4_K_M.gguf}}"
DEV="${DEV:-Vulkan0}"
MAXNEW="${MAXNEW:-1024}"

command -v llama-cli >/dev/null || { echo "llama-cli not found (pacman -S llama-cpp-vulkan)"; exit 1; }
[ -f "$MODEL" ] || { echo "model not found: $MODEL"; exit 1; }

cd "$(dirname "$0")"
echo "building infr..."
cargo build -q -p infr-cli --release
INFR=target/release/infr

ierr=$(mktemp); lerr=$(mktemp); lout=$(mktemp)
trap 'rm -f "$ierr" "$lerr" "$lout"' EXIT

num() { { grep -oP "$1" <"$2" || true; } | tail -1; }   # last match of a PCRE group (never fails)

printf '\n========== infr ==========\n'
INFR_MAX_NEW="$MAXNEW" "$INFR" run "$MODEL" "$PROMPT" 2>"$ierr"
i_pf=$(num 'prefill \d+ tok @ \K[0-9.]+' "$ierr")
i_dec=$(num 'decode \d+ tok @ \K[0-9.]+' "$ierr")

printf '\n========== llama.cpp ==========\n'
# llama-cli prints its `[ Prompt | Generation ]` summary on STDOUT and llama_perf on STDERR.
llama-cli -m "$MODEL" -ngl 99 -dev "$DEV" -fa auto -st -n "$MAXNEW" -p "$PROMPT" 2>"$lerr" | tee "$lout"
l_pf=$(num 'Prompt:\s*\K[0-9.]+' "$lout")
l_dec=$(num 'Generation:\s*\K[0-9.]+' "$lout")
# fallback to llama_perf lines (stderr) if the bracket summary wasn't printed
if [ -z "$l_pf" ]; then l_pf=$(num 'prompt eval time.*?\(\s*\K[0-9.]+(?= tokens per second)' "$lerr"); fi
if [ -z "$l_dec" ]; then l_dec=$(num 'eval time.*?\(\s*\K[0-9.]+(?= tokens per second)' "$lerr"); fi

ratio() { [ -z "${1:-}" ] || [ -z "${2:-}" ] && { echo -; return; }; awk "BEGIN{printf \"%.2fx\", $1/$2}"; }
printf '\n========== speed (tok/s) ==========\n'
printf '%-10s | %10s | %10s | %8s\n' "" "infr" "llama.cpp" "infr/llama"
printf -- '-----------+------------+------------+---------\n'
printf '%-10s | %10s | %10s | %8s\n' "prefill" "${i_pf:-?}" "${l_pf:-?}" "$(ratio "${i_pf:-}" "${l_pf:-}")"
printf '%-10s | %10s | %10s | %8s\n' "decode"  "${i_dec:-?}" "${l_dec:-?}" "$(ratio "${i_dec:-}" "${l_dec:-}")"
